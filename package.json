{
  "name": "devops-accelerator-demo",
  "version": "1.0.0",
  "description": "Deliberately insecure Node.js API — demonstrates the AI DevSecOps Control Plane",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "jest --ci --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "verbose": true,
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 10000
  },
  "dependencies": {
    "axios": "^1.16.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "lodash": "^4.18.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^6.3.4"
  }
}
